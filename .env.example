# =============================================================================
# Supabase (obrigatório para CMS / loja dinâmica)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# Schema PostgreSQL da loja (NÃO usar public — BD compartilhado)
SUPABASE_DB_SCHEMA=ecommerce-amooora

# Bucket Storage da loja (isolado do restante do projeto Supabase)
SUPABASE_STORAGE_BUCKET=ecommerce-amooora-produtos

# Apenas server-side (admin, uploads, bypass RLS quando necessário)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# =============================================================================
# Admin MVP (login simples antes de Supabase Auth estar configurado)
# =============================================================================
ADMIN_EMAIL=admin@amooora.com.br
ADMIN_PASSWORD=altere-esta-senha

# Sessão do admin MVP (gerar: openssl rand -base64 32)
ADMIN_SESSION_SECRET=gerar-um-secret-aleatorio

# =============================================================================
# WhatsApp — fallback quando produto não tem CTA próprio
# =============================================================================
WHATSAPP_DEFAULT_PHONE=5511970548406

# =============================================================================
# App
# =============================================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
